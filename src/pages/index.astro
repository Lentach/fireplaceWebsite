---
import '../styles/landing.css';
const app = 'https://fireplace.ignorelist.com/';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, interactive-widget=resizes-visual" />
  <title>Fireplace — messages only two people can read</title>
  <meta name="description" content="End-to-end encrypted chat. Signal protocol on every message, delete removes both sides. Follow one message end to end and see exactly what our server sees: nothing readable." />
  <meta property="og:title" content="Fireplace — messages only two people can read" />
  <meta property="og:description" content="E2E encrypted chat built by one guy. Follow one message end to end — including the only stop we own." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://fireplace.ignorelist.com/welcome/" />
  <meta property="og:image" content="https://fireplace.ignorelist.com/welcome/og.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Fireplace — follow one encrypted message from a phone, through the relay we run, to the other phone." />
  <meta property="og:site_name" content="Fireplace" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Fireplace — messages only two people can read" />
  <meta name="twitter:description" content="E2E encrypted chat built by one guy. Follow one message end to end — including the only stop we own." />
  <meta name="twitter:image" content="https://fireplace.ignorelist.com/welcome/og.png" />
  <meta name="twitter:image:alt" content="Fireplace — an encrypted message travels from one phone to another across a relay that can't read it." />
  <meta name="theme-color" content="#000000" />
  <link rel="canonical" href="https://fireplace.ignorelist.com/welcome/" />
  <link rel="icon" type="image/svg+xml" href="favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;700;900&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
<div class="grain"></div>

<nav>
  <button class="mark" type="button" title="Refresh">FIRE<b>PLACE</b></button>
  <div class="links">
    <a href="#journey">How it works</a>
    <a href="#features">Privacy</a>
    <a class="cta" href={app} target="_blank" rel="noopener noreferrer">Open app</a>
  </div>
</nav>

<button class="skip-tour" type="button" aria-label="Skip the tour">
  <svg viewBox="0 0 28 26" aria-hidden="true">
    <path class="c1" d="M6 7 14 14 22 7" />
    <path class="c2" d="M6 13 14 20 22 13" />
  </svg>
</button>
<button class="kb-done" type="button">Done ✓</button>

<!-- ============ HERO ============ -->
<section class="hero">
  <canvas></canvas>
  <div class="content">
    <p class="tag">E2E encrypted chat · sealed on your device · your words never reach us readable</p>
    <h1>Messages only<br /><span>two people</span><br />can read.</h1>
    <p class="sub">Every message is sealed on your device with the Signal protocol before it touches the network. Our server relays ciphertext between the people you trust — and understands none of it.</p>
    <div class="enc" data-encrypt></div>
  </div>
  <span class="scroll-cue">scroll — follow one message ↓</span>
</section>

<!-- ============ THE JOURNEY ============ -->
<section class="journey" id="journey">
  <div class="stage">
    <canvas></canvas>

    <div class="prompt">
      <h1>Where does a message<br /><span>actually go?</span></h1>
      <p>press send — or just keep scrolling</p>
    </div>

    <!-- sender phone -->
    <div class="phone sender">
      <div class="screen">
        <div class="bar"><span class="ava warm">B</span><span class="who">Bob<small>online · encrypted</small></span><span class="lock">🔒</span></div>
        <div class="msgs sender-msgs">
          <div class="m them">so, does your app actually work? 😄<div class="meta">08:11</div></div>
          <div class="m me">you're about to find out<div class="meta">08:11 ✓✓</div></div>
        </div>
        <div class="compose">
          <div class="c-row">
            <div class="c-pill">
              <svg class="c-ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 14l6-6 6 6"/></svg>
              <span class="c-caret" aria-hidden="true"></span>
              <textarea rows="1" placeholder="Message" maxlength="120" spellcheck="false">sending very sensitive data — safe here</textarea>
            </div>
            <button title="send">➤</button>
          </div>
          <div class="c-tools" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M4 7h16M9 7V5h6v2M6 7l1 13h10l1-13M10 11l4 4M14 11l-4 4"/></svg>
            <svg viewBox="0 0 24 24"><path d="M7 4h10l-4.2 8L17 20H7l4.2-8L7 4z"/><circle cx="19" cy="5" r="2.4" class="dot"/></svg>
            <svg viewBox="0 0 24 24"><path d="M12 4v16M5 8l14 8M19 8L5 16"/></svg>
            <svg viewBox="0 0 24 24"><path d="M20.5 12.5L12 21a5.2 5.2 0 0 1-7.4-7.4L13.4 4.8a3.5 3.5 0 0 1 5 5L9.6 18.6a1.8 1.8 0 0 1-2.6-2.6L15.5 7.5"/></svg>
            <svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="3.5"/><text x="12" y="15.5" text-anchor="middle" class="giftxt">GIF</text></svg>
            <svg viewBox="0 0 24 24"><path d="M10 3h4M11 3v5.2L5.6 17a3 3 0 0 0 2.7 4h7.4a3 3 0 0 0 2.7-4L13 8.2V3"/></svg>
          </div>
        </div>
      </div>
    </div>
    <span class="keytag sender-key">🔑 Bob's key — never leaves his device</span>

    <!-- the relay node — the canvas draws a dot-shell around this core;
         the journey reveals it through a clip-circle synced to the shell's
         iris. IN/OUT ports live on the shell (canvas), not in the DOM. -->
    <div class="machine">
      <div class="mc-head"><span class="lbl"><span class="dotpulse"></span> fireplace relay nº1<span class="lbl-tail"> · the only stop we own</span></span></div>
      <div class="core">
        <div class="ring r1" data-rotor></div>
        <div class="ring r2" data-rotor></div>
        <div class="nucleus"></div>
        <div class="sv-stream"></div>
      </div>
      <div class="mc-stamp">routes everything · reads nothing</div>
    </div>

    <!-- recipient phone -->
    <div class="phone recipient">
      <div class="screen">
        <div class="bar"><span class="ava">K</span><span class="who">Kate<small>online · encrypted</small></span><span class="lock">🔒</span></div>
        <div class="msgs recipient-msgs">
          <div class="m me">so, does your app actually work? 😄<div class="meta">08:11 ✓✓</div></div>
          <div class="m them">you're about to find out<div class="meta">08:11</div></div>
        </div>
        <div class="compose">
          <div class="c-row">
            <div class="c-pill">
              <svg class="c-ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 14l6-6 6 6"/></svg>
              <span class="c-caret" aria-hidden="true"></span>
              <textarea rows="1" placeholder="Message" maxlength="120" spellcheck="false" disabled></textarea>
              <svg class="c-ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a3 3 0 0 1 3 3v5a3 3 0 0 1-6 0V6a3 3 0 0 1 3-3zM5 11a7 7 0 0 0 14 0M12 18v3"/></svg>
            </div>
            <button title="send" disabled>➤</button>
          </div>
          <div class="c-tools" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M4 7h16M9 7V5h6v2M6 7l1 13h10l1-13M10 11l4 4M14 11l-4 4"/></svg>
            <svg viewBox="0 0 24 24"><path d="M7 4h10l-4.2 8L17 20H7l4.2-8L7 4z"/><circle cx="19" cy="5" r="2.4" class="dot"/></svg>
            <svg viewBox="0 0 24 24"><path d="M12 4v16M5 8l14 8M19 8L5 16"/></svg>
            <svg viewBox="0 0 24 24"><path d="M20.5 12.5L12 21a5.2 5.2 0 0 1-7.4-7.4L13.4 4.8a3.5 3.5 0 0 1 5 5L9.6 18.6a1.8 1.8 0 0 1-2.6-2.6L15.5 7.5"/></svg>
            <svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="3.5"/><text x="12" y="15.5" text-anchor="middle" class="giftxt">GIF</text></svg>
            <svg viewBox="0 0 24 24"><path d="M10 3h4M11 3v5.2L5.6 17a3 3 0 0 0 2.7 4h7.4a3 3 0 0 0 2.7-4L13 8.2V3"/></svg>
          </div>
        </div>
      </div>
    </div>
    <span class="keytag recipient-key">🔑 Kate's key — the only other one in existence</span>

    <div class="traveler"></div>

    <!-- captions -->
    <div class="cap" data-a="0.045" data-b="0.12">
      <span class="num">01 / LIFT-OFF</span>
      <h2>Sent. But not<br />like the others.</h2>
      <p>Before Bob's message touches any network, something happens right here on his device.</p>
    </div>
    <div class="cap" data-a="0.13" data-b="0.25">
      <span class="num">02 / SEALED</span>
      <h2>Encrypted where<br />it was written.</h2>
      <p>Signal double-ratchet. A fresh key for every message. The "3:" envelope is all that survives — and the key stays on his phone.</p>
    </div>
    <div class="cap" data-a="0.28" data-b="0.42">
      <span class="num">03 / IN TRANSIT</span>
      <h2>Ciphertext,<br />inside TLS.</h2>
      <p>Two layers of locks cross the wire. Anyone listening — provider, wifi, anyone — records noise.</p>
    </div>
    <div class="cap" data-a="0.44" data-b="0.64">
      <span class="num">04 / THE RELAY MACHINE</span>
      <h2>In sealed.<br />Out sealed.</h2>
      <p>Our machine shuffles envelopes, never opens them. Every row in its window looks exactly like Bob's: ciphertext and routing metadata. No key exists here — nothing to read, leak, sell, or subpoena.</p>
    </div>
    <div class="cap" data-a="0.67" data-b="0.81">
      <span class="num">05 / RELAYED</span>
      <h2>We pass the letter.<br />Still sealed.</h2>
      <p>The envelope moves the instant Kate is reachable. We keep ciphertext for delivery — never a readable word.</p>
    </div>
    <div class="cap" data-a="0.84" data-b="0.955">
      <span class="num">06 / UNSEALED</span>
      <h2>Only Kate's phone<br />can do this.</h2>
      <p>Kate's device holds the only matching key in existence. The ratchet turns, the seal opens — and it lands on her screen.</p>
    </div>
    <div class="cap turn" data-a="0.955" data-b="1.2">
      <span class="num">07 / KATE'S TURN</span>
      <h2>Now reply.</h2>
      <p>Type in Kate's composer — the answer rides the same rail back, sealed on her phone, opened only on his. Scroll up and watch it fly.</p>
      <p class="m-short">Kate's composer is live — type, then scroll up ↑</p>
    </div>

    <div class="rail">
      <div class="stop" data-p="0.02"><div class="d"></div><span>Bob's device</span></div><div class="seg"></div>
      <div class="stop" data-p="0.26"><div class="d"></div><span>wire</span></div><div class="seg"></div>
      <div class="stop" data-p="0.43"><div class="d"></div><span>relay</span></div><div class="seg"></div>
      <div class="stop" data-p="0.66"><div class="d"></div><span>wire</span></div><div class="seg"></div>
      <div class="stop" data-p="0.83"><div class="d"></div><span>Kate's device</span></div>
    </div>

    <span class="journey-hint">scroll — your message is on its way ↓</span>
  </div>
</section>

<!-- ============ LIGHT ZONE ============ -->
<div id="lightZone">
  <div class="bridge"></div>
  <section class="features" id="features">
    <h2>Private by construction,<br /><span>not by promise.</span></h2>
    <div class="grid">
      <div class="card">
        <span class="k">Sealed</span>
        <h3>Signal protocol, every message</h3>
        <p>Double-ratchet end-to-end encryption by default — there is no unencrypted mode. Keys are generated and stay on your device; the server never sees them.</p>
      </div>
      <div class="card">
        <span class="k">Blind</span>
        <h3>A server that knows nothing</h3>
        <p>Our relay stores sealed envelopes and routing metadata — your words cross it unreadable. No ads, no analytics resale, no "partners". Even our backups can't read your messages.</p>
      </div>
      <div class="card">
        <span class="k">Ephemeral</span>
        <h3>Deleting actually deletes</h3>
        <p>Delete for everyone removes the message on both sides — server included. Edit window of 15 minutes, re-encrypted end-to-end like everything else.</p>
      </div>
    </div>
  </section>
  <section class="ledger">
    <div class="strip">
      <span>message text: <b>ciphertext only</b></span>
      <span><b>E2E</b> on by default</span>
      <span>delete removes <b>both sides</b></span>
      <span>keys <b>never leave</b> your device</span>
      <span>built by <b>one guy</b></span>
    </div>
  </section>
</div>
<div class="bridge-up"></div>

<!-- ============ OUTRO ============ -->
<section class="outro">
  <canvas></canvas>
  <div class="content">
    <span class="kick"><span class="kdot"></span> relay nº1 · still humming</span>
    <h2>That's the whole story.<br /><span>We're just the courier.</span></h2>
    <a class="cta" href={app} target="_blank" rel="noopener noreferrer"><span class="slit" aria-hidden="true"></span>Open Fireplace</a>
    <p class="fine">runs in your browser · installs as an app · free</p>
  </div>
</section>

<footer>
  <div class="f-wire" aria-hidden="true"><span class="f-photon"></span></div>
  <div class="f-row">
    <span class="f-mark">FIRE<b>PLACE</b> · end-to-end encrypted chat</span>
    <span class="f-honest">no analytics on this page — your scroll stays yours</span>
    <span class="f-made"><a href="https://github.com/Lentach" rel="author">github.com/Lentach</a></span>
  </div>
</footer>

<script>
  import '../scripts/main';
</script>
</body>
</html>
